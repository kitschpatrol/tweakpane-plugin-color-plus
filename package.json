{
	"name": "tweakpane-plugin-color-plus",
	"version": "0.3.0",
	"description": "Advanced color handling for Tweakpane.",
	"keywords": [
		"color",
		"npm-package",
		"tweakpane",
		"tweakpane-plugin"
	],
	"homepage": "https://github.com/kitschpatrol/tweakpane-plugin-color-plus",
	"bugs": "https://github.com/kitschpatrol/tweakpane-plugin-color-plus/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kitschpatrol/tweakpane-plugin-color-plus.git"
	},
	"license": "MIT",
	"author": {
		"name": "Eric Mika",
		"email": "eric@ericmika.com",
		"url": "https://ericmika.com"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"default": "./dist/tweakpane-plugin-color-plus.js"
		},
		"./lite": {
			"types": "./dist/types/index.d.ts",
			"default": "./dist/tweakpane-plugin-color-plus.lite.js"
		}
	},
	"main": "dist/tweakpane-plugin-color-plus.js",
	"types": "dist/types/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "run-p build:*",
		"build:dev": "tsdown",
		"build:dts": "rimraf ./dist/types && tsc --project src/tsconfig-dts.json",
		"build:prod": "cross-env BUILD=production tsdown",
		"clean": "shx rm -f pnpm-lock.yaml && git clean -fdX -e !.claude/",
		"dev": "vite",
		"dev:cdn": "vite ./demo/cdn --open",
		"dev:npm": "vite ./demo/npm --open",
		"dev:screenshot": "vite ./demo/screenshot --open",
		"fix": "ksc fix",
		"lint": "ksc lint",
		"release": "bumpp --commit 'Release: %s' --tag '%s' && pnpm build && NPM_AUTH_TOKEN=$(op read 'op://Personal/npm/token') pnpm publish",
		"start": "run-p watch dev",
		"test": "vitest run",
		"watch": "run-p watch:*",
		"watch:dts": "onchange --initial --kill \"src/**/*.ts\" -- pnpm build:dts",
		"watch:sass": "onchange --initial --kill \"src/sass/**/*.scss\" -- pnpm build:dev",
		"watch:ts": "onchange --initial --kill \"src/**/*.ts\" -- pnpm build:dev"
	},
	"dependencies": {
		"@tweakpane/core": "^2.0.5"
	},
	"devDependencies": {
		"@kitschpatrol/shared-config": "^7.6.1",
		"@types/node": "^20.19.41",
		"autoprefixer": "^10.5.0",
		"bumpp": "^11.1.0",
		"colorjs.io": "^0.6.1",
		"cross-env": "^10.1.0",
		"npm-run-all": "^4.1.5",
		"onchange": "^7.1.0",
		"postcss": "^8.5.14",
		"rimraf": "^6.1.3",
		"sass": "^1.99.0",
		"shx": "^0.4.0",
		"tsdown": "^0.22.0",
		"tweakpane": "^4.0.5",
		"typescript": "~5.9.3",
		"vite": "^8.0.13",
		"vitest": "^4.1.6"
	},
	"peerDependencies": {
		"tweakpane": "^4.0.0"
	},
	"packageManager": "pnpm@11.1.2",
	"engines": {
		"node": ">=20.19.0"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": ">=22.22.2"
		}
	}
}
